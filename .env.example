# Copy to .env for local dev, and set these in Vercel:
# Project Settings -> Environment Variables (Production + Preview).

# MongoDB connection string. On Vercel, point this at a free MongoDB Atlas
# M0 cluster (replaces the Genezio-managed mongo-atlas database).
MY_MONGO_DB_DATABASE_URL=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/triumf-tenis?retryWrites=true&w=majority

# Google service account used to read the schedule spreadsheet from Drive.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private key for the service account above.
# Keep the literal \n escapes — the code converts them to real newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# ID of the Excel file on Google Drive that holds the bookings.
GOOGLE_SPREADSHEET_ID=your-google-drive-file-id
